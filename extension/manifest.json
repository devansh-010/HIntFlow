{
  "manifest_version": 3,
  "name": "HintFlow",
  "version": "1.0",
  "description": "AI DSA Mentor",

  "host_permissions": [
    "http://localhost:5000/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}